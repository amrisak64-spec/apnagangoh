rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // ── listing images ────────────────────────────────────────────
    // Path: listings/{uid}/{listingId}/{fileName}
    match /listings/{uid}/{listingId}/{fileName} {
      // Anyone can read (listing images are public)
      allow read: if true;

      // Only the authenticated owner can upload to their own path
      allow write: if request.auth != null
                   && request.auth.uid == uid
                   // Images only
                   && request.resource.contentType.matches('image/.*')
                   // Max 2 MB per image (compressed before upload)
                   && request.resource.size <= 2 * 1024 * 1024;

      allow delete: if request.auth != null && request.auth.uid == uid;
    }

    // Block everything else
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
